---
// src/pages/join.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Join | SKŌGARD"
  description="Join the SKŌGARD volunteer network and stay ready for future local action."
>
  <section class="section">
    <div class="shell prose">
      <p class="eyebrow">Join</p>
      <h1>Join the network</h1>
      <p>
        This page is a placeholder for future signup flows. For now, it marks the place where
        volunteer intake, contact preferences, and regional routing can be added cleanly.
      </p>
      <div class="card form-placeholder" role="group" aria-labelledby="join-form-title">
        <h2 id="join-form-title">Placeholder form area</h2>
        <p>
          Future fields may include name, email, zip code, interests, and availability. Keep this
          flow simple, accessible, and respectful of data collection.
        </p>
        <p><strong>Status:</strong> Static placeholder. No data is submitted yet.</p>
      </div>
    </div>
  </section>
</BaseLayout>
