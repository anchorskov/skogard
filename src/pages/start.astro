---
// src/pages/start.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Start a Group | SKŌGARD"
  description="Learn how SKŌGARD can expand into local groups with a clear and simple foundation."
>
  <section class="section">
    <div class="shell prose">
      <p class="eyebrow">Start a Group</p>
      <h1>Start a local group</h1>
      <p>
        This page is a placeholder for future guidance on starting a SKŌGARD group in a town,
        neighborhood, campus, or region.
      </p>
      <div class="card">
        <h2>What this page can grow into</h2>
        <p>
          Add a starter checklist, expectations for local organizers, basic safety guidance,
          outreach suggestions, and a path for connecting new groups back to the wider network.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
